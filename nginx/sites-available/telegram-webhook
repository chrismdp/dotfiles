server {
    server_name vps.chrismdp.com;

    # Telegram webhook — no auth (Telegram validates via secret token header)
    location /telegram-webhook {
        proxy_pass http://127.0.0.1:8787;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Review Board — vault project review web app
    location /review/ {
        proxy_pass http://127.0.0.1:8800/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 86400s;
    }

    # Voice inbox — iOS Shortcuts audio drop
    # Auth via Authorization: Bearer <token> checked inside the app
    location /voice {
        proxy_pass http://127.0.0.1:8790;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 50M;
        proxy_read_timeout 120s;
        proxy_request_buffering off;
    }

    location = /voice/health {
        proxy_pass http://127.0.0.1:8790/health;
    }

    # Block everything else
    location / {
        return 404;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/vps.chrismdp.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/vps.chrismdp.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = vps.chrismdp.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name vps.chrismdp.com;
    return 404; # managed by Certbot


}