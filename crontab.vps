# VPS crontab — SOURCE OF TRUTH.
# Install with: crontab ~/code/dotfiles/crontab.vps
# NEVER use `crontab -e` directly on this VPS. Always edit this file first, commit,
# then re-install. See the rule in ~/vault/CLAUDE.md.
#
# Previous drift incident (2026-04-06 → 2026-04-08): the live crontab had extra
# entries not in this file. The dotfile was re-installed around the kernel-upgrade
# reboot and clobbered overnight, leann rebuild, LinkedIn sync script name, and
# inbox collection cadence. Fixed 2026-04-08.

# ---- Vault & sync ----

# Rotate agent stream logs (keep last 1MB to preserve tail context)
0 0 * * * truncate -s 1048576 /tmp/worker-1-stream.jsonl /tmp/heartbeat-stream.jsonl 2>/dev/null

# Prune daily-rotated worker usage logs older than 30 days (per-turn token+cost data)
5 0 * * * find /tmp -maxdepth 1 -name 'worker-*-usage-*.jsonl' -mtime +30 -delete 2>/dev/null

# Prune raw pi request payloads older than 14 days (set by run-worker.sh via PI_LOG_REQUESTS)
6 0 * * * find /tmp/pi-requests -mindepth 1 -mtime +14 -delete 2>/dev/null

# Vault git backup (5 min)
*/5 * * * * ~/bin/vault-sync.sh >> ~/bin/vault-sync.log 2>&1

# Google Drive transcript sync
*/20 * * * * ~/bin/sync-drive-transcripts.sh

# ---- Inbox / heartbeat loop ----

# Inbox collection (fast — deterministic bash, no LLM tokens)
*/5 6-23 * * * flock -n /tmp/collect.lock /home/cp/.claude/skills/heartbeat/scripts/collect.sh >> /tmp/collect.log 2>&1

# Heartbeat agent (reminders, briefings, project transitions) — now via pi
*/15 6-23 * * * /home/cp/.claude/skills/heartbeat/scripts/run-heartbeat-pi.sh
0 4 * * * /home/cp/.claude/skills/heartbeat/scripts/clean-heartbeat-sent.sh

# ---- Daily batch work ----

# Overnight sweep at 06:00 UTC — content check, service health, daily note shell, webinar check, BAU project creation
# Heavy steps split out 2026-05-06 to spread cron network load (Hostinger suspensions)
0 6 * * * /home/cp/.claude/skills/overnight/scripts/run-overnight.sh

# PostHog anomaly scan at 06:00 UTC — daily product analytics health across all projects, Telegram if anomalies
0 6 * * * /home/cp/.claude/skills/posthog-scan/scripts/run.sh

# Process yesterday's CC sessions at 06:30 UTC — activity summary + wiki ingest (was Step 1 of /overnight)
30 6 * * * /home/cp/.claude/skills/process-sessions/scripts/run.sh

# Bluesky feed curator at 07:00 UTC — unfollow US partisan culture-war accounts, follow high-signal AI, Telegram report if anything changed
0 7 * * * /home/cp/.claude/skills/bluesky/scripts/run.sh

# Airskills Pro trial-signup digest at 08:00 UTC — Telegram roll-up of new pro_trial_requests since last run, silent if none (real-time per-signup Telegram already fires from the API route)
0 8 * * * . ~/.secret_env && /home/cp/vault/scripts/airskills-trial-digest.sh >> /tmp/airskills-trial-digest.log 2>&1

# Financial reconciliation at 12:00 UTC = 1pm BST / midday GMT — Xero receipts + YNAB (was Step 2 of /overnight)
0 12 * * * /home/cp/.claude/skills/process-financial/scripts/run.sh

# Nightly dream — 20:00 UTC (21:00 BST). Each run rolls a fresh lens (pick-lens.sh) to surface different threads. State lives in the vault at ~/vault/.dream-state/dreams.jsonl (overridable via $DREAM_STATE_DIR).
0 20 * * * /home/cp/.claude/skills/dream/scripts/run.sh

# Telegram project-map cleanup
0 4 * * * /home/cp/.claude/skills/telegram/scripts/project-map.sh clean >> /tmp/telegram-webhook.log 2>&1

# LEANN vault index rebuild (incremental, content-hash change detection)
17 4 * * * . ~/.secret_env && XDG_RUNTIME_DIR=/run/user/1001 systemd-run --user --scope -p CPUQuota=25% -p TasksMax=8 --quiet -- nice -n 19 leann build obs-vault --docs ~/vault ~/code/blog/_posts ~/code/blog/pages --embedding-model text-embedding-3-large --embedding-mode openai --file-types '.md' --num-threads 1 >> /tmp/leann-rebuild.log 2>&1

# Claude Code session export (every 30 min — writes today's sessions to vault for cross-machine aggregation)
*/30 * * * * python3 ~/.claude/skills/process-sessions/export_claude_sessions.py --today >/dev/null 2>&1

# ---- Integrations ----

# LinkedIn post sync via Zernio API
0 9,13 * * * . ~/.secret_env && python3 ~/.claude/skills/linkedin-sync/scripts/sync_zernio.py >> ~/vault/tmp/linkedin-sync.log 2>&1

# Mapcamp monitor
0 9 * * * . ~/.secret_env && python3 /home/cp/scripts/monitor-mapcamp.py >> /tmp/monitor-mapcamp.log 2>&1

# Home Assistant camera snapshots -> Google Drive (noon UK time)
0 11,12 * * * /home/cp/scripts/ha-snapshots.sh

# Calendar-aware HA state (every 15 min): pushes binary_sensor.chris_on_holiday
# (from chris.p@rsons.org OOO events — used by heater_morning_up to skip on holidays),
# sensor.outdoor_temperature (from weather entity, for long-term stats),
# and sensor.office_temperature_c (Fahrenheit source converted to Celsius).
*/15 * * * * /home/cp/.claude/skills/home/scripts/ha-calendar-status.py >> /tmp/ha-calendar-status.log 2>&1

# Litter tray check (15:00 UK time; sleeps until sunset+15, capped at 21:00, snapshots + Gemini verdict)
# DISABLED 2026-05-23 (Chris asked to stop — Poppins doing it now): 0 14,15 * * * /home/cp/.claude/skills/home/scripts/litter-tray-check.sh

# DISABLED 2026-05-26 (Chris asked to stop — Poppins doing it now): 0 8 * * 2 . ~/.secret_env && python3 ~/vault/scripts/everyman-winchester-check.py >> /tmp/everyman-check.log 2>&1

# ---- Batched Telegram digests ----
# Slot times (London local): weekdays 09:00 / 13:00 / 17:30 / 21:00; weekends + holidays 13:30 only.
# Cron fires at both UTC times (BST and GMT) for each slot; the wrapper (run-digest-if-due.sh) reads
# Europe/London local time and only fires when it matches a configured slot for the current day mode.
# Mode rules: weekday = Mon-Fri AND no ~/vault/tmp/on-holiday flag; otherwise weekend mode.
# Urgent path bypasses this entirely (see enqueue.sh --urgent and triage/references/telegram-rules.md).
0 8,9 * * * /home/cp/.claude/skills/triage/scripts/run-digest-if-due.sh weekday
0 12,13 * * * /home/cp/.claude/skills/triage/scripts/run-digest-if-due.sh weekday
30 12,13 * * * /home/cp/.claude/skills/triage/scripts/run-digest-if-due.sh weekend
30 16,17 * * * /home/cp/.claude/skills/triage/scripts/run-digest-if-due.sh weekday
0 20,21 * * * /home/cp/.claude/skills/triage/scripts/run-digest-if-due.sh weekday

