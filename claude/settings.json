{
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_run_code",
      "mcp__playwright__browser_snapshot",
      "WebFetch",
      "Read(/home/cp/**)",
      "Read(~/**)",
      "Grep(/home/cp/**)",
      "Grep(~/**)",
      "Glob(/home/cp/**)",
      "Glob(~/**)",
      "Read(/tmp/**)",
      "Write(~/Pictures/**)",
      "Edit(~/Pictures/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)",
      "Write(~/vault/blog/**)",
      "Edit(~/vault/blog/**)",
      "mcp__perplexity__perplexity_ask",
      "mcp__perplexity__perplexity_search",
      "mcp__perplexity__perplexity_research",
      "mcp__perplexity__perplexity_reason",
      "Bash(/home/cp/code/codemap/hooks/file-activity-hook.sh read:*)",
      "Bash(/home/cp/code/codemap/hooks/file-activity-hook.sh write:*)",
      "Bash(/home/cp/code/codemap/hooks/thinking-hook.sh thinking-start:*)",
      "Bash(/home/cp/code/codemap/hooks/thinking-hook.sh thinking-end:*)"
    ],
    "deny": [],
    "ask": [
      "Bash(*lockbox-prompt*)",
      "Bash(gog gmail send:*)",
      "Agent(lockbox:delegate)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/today-in-claude-code/export_claude_sessions.py --today",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cp/code/codemap/hooks/file-activity-hook.sh read-start"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cp/code/codemap/hooks/file-activity-hook.sh write-start"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cp/code/codemap/hooks/thinking-hook.sh thinking-end"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cp/code/codemap/hooks/file-activity-hook.sh read-end"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cp/code/codemap/hooks/file-activity-hook.sh write-end"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cp/code/codemap/hooks/thinking-hook.sh thinking-start"
          },
          {
            "type": "command",
            "command": "/home/cp/code/agent-coordination-bus/hooks/post-tool.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cp/code/codemap/hooks/thinking-hook.sh thinking-end"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "lockbox@chrismdp": false
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
