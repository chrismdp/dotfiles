{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Monitor",
      "WebSearch",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_run_code",
      "mcp__playwright__browser_snapshot",
      "WebFetch",
      "Read(/home/cp/**)",
      "Read(~/**)",
      "Grep(/home/cp/**)",
      "Grep(~/**)",
      "Glob(/home/cp/**)",
      "Glob(~/**)",
      "Read(/tmp/**)",
      "Write(~/Pictures/**)",
      "Edit(~/Pictures/**)",
      "Write(/tmp/**)",
      "Edit(/tmp/**)",
      "Write(~/vault/blog/**)",
      "Edit(~/vault/blog/**)",
      "mcp__perplexity__perplexity_ask",
      "mcp__perplexity__perplexity_search",
      "mcp__perplexity__perplexity_research",
      "mcp__perplexity__perplexity_reason",
      "mcp__posthog__:*"
    ],
    "deny": [],
    "ask": [
      "Bash(*lockbox-prompt*)",
      "Bash(gog gmail send:*)",
      "Agent(lockbox:delegate)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/skills/process-sessions/export_claude_sessions.py --today",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && { name=$(tmux display-message -p -t \"$TMUX_PANE\" '#W'); tmux rename-window -t \"$TMUX_PANE\" \"${name#ÔØû }\"; } >/dev/null 2>&1; true"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && { name=$(tmux display-message -p -t \"$TMUX_PANE\" '#W'); tmux set-window-option -t \"$TMUX_PANE\" automatic-rename off; clean=\"${name#Ôùë }\"; clean=\"${clean#Ôùê }\"; clean=\"${clean#ÔØû }\"; tmux rename-window -t \"$TMUX_PANE\" \"Ôùê ${clean}\"; } >/dev/null 2>&1; true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/cp/code/agent-coordination-bus/hooks/post-tool.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && { name=$(tmux display-message -p -t \"$TMUX_PANE\" '#W'); tmux rename-window -t \"$TMUX_PANE\" \"${name#Ôùê }\"; } >/dev/null 2>&1; true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && { name=$(tmux display-message -p -t \"$TMUX_PANE\" '#W'); tmux set-window-option -t \"$TMUX_PANE\" automatic-rename off; clean=\"${name#Ôùë }\"; clean=\"${clean#Ôùê }\"; clean=\"${clean#ÔØû }\"; tmux rename-window -t \"$TMUX_PANE\" \"ÔØû ${clean}\"; } >/dev/null 2>&1; true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && { name=$(tmux display-message -p -t \"$TMUX_PANE\" '#W'); tmux set-window-option -t \"$TMUX_PANE\" automatic-rename off; clean=\"${name#Ôùë }\"; clean=\"${clean#Ôùê }\"; clean=\"${clean#ÔØû }\"; tmux rename-window -t \"$TMUX_PANE\" \"ÔØû ${clean}\"; } >/dev/null 2>&1; true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && { name=$(tmux display-message -p -t \"$TMUX_PANE\" '#W'); tmux set-window-option -t \"$TMUX_PANE\" automatic-rename off; clean=\"${name#Ôùë }\"; clean=\"${clean#Ôùê }\"; clean=\"${clean#ÔØû }\"; tmux rename-window -t \"$TMUX_PANE\" \"Ôùë ${clean}\"; } >/dev/null 2>&1; true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMUX\" ] && { name=$(tmux display-message -p -t \"$TMUX_PANE\" '#W'); clean=\"${name#Ôùë }\"; clean=\"${clean#Ôùê }\"; clean=\"${clean#ÔØû }\"; tmux rename-window -t \"$TMUX_PANE\" \"${clean}\"; } >/dev/null 2>&1; true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/bin/bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "lockbox@chrismdp": false,
    "ruby-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": false,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
